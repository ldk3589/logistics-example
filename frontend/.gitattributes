# ===============================
# 基础规则
# ===============================

* text=auto

# ===============================
# 前端源码
# ===============================

*.js   text eol=lf
*.ts   text eol=lf
*.vue  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.scss text eol=lf
*.html text eol=lf

# ===============================
# 配置文件
# ===============================

*.env      text eol=lf
*.env.*    text eol=lf
vite.config.* text eol=lf

# ===============================
# Markdown & 文档
# ===============================

*.md text eol=lf

# ===============================
# 日志文件
# ===============================

*.log text eol=lf linguist-generated

# ===============================
# 二进制文件
# ===============================

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# ===============================
# 构建产物 & 依赖
# ===============================

dist/** linguist-generated
node_modules/** linguist-generated
