# ===============================
# 基础规则
# ===============================

* text=auto

# ===============================
# Java 源码
# ===============================

*.java text eol=lf
*.xml  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.properties text eol=lf

# ===============================
# Maven / Gradle
# ===============================

pom.xml text eol=lf
*.gradle text eol=lf

# ===============================
# 脚本文件
# ===============================

*.sh  text eol=lf
*.bat text eol=crlf

# ===============================
# 日志文件
# ===============================

*.log text eol=lf linguist-generated

# ===============================
# 二进制文件（不做 diff）
# ===============================

*.jar binary
*.war binary
*.zip binary
*.gz  binary

# ===============================
# IDE & 工具
# ===============================

*.iml text linguist-generated
.idea/** linguist-generated
.target/** linguist-generated
